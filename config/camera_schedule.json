{
  "schema_version": 1,
  "capture": {
    "width": 640,
    "height": 480,
    "fps": 15,
    "preferred_format": "MJPEG",
    "queue_depth": 1
  },
  "vision_runtime": {
    "max_total_inference_hz": 12,
    "max_concurrent_inference": 1,
    "intra_op_threads": 2,
    "inter_op_threads": 1,
    "input_width": 320,
    "input_height": 320
  },
  "policy_runtime": {
    "raw_image_input": false,
    "intra_op_threads": 1,
    "default_rate_hz": 10
  },
  "phases": {
    "STANDBY": {
      "top": {"decode_hz": 1, "inference_hz": 1},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 0, "inference_hz": 0},
      "policy_hz": 0
    },
    "SEARCH": {
      "top": {"decode_hz": 10, "inference_hz": 8},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 0, "inference_hz": 0},
      "policy_hz": 0
    },
    "APPROACH_RIGHT": {
      "top": {"decode_hz": 6, "inference_hz": 4},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 8, "inference_hz": 6},
      "policy_hz": 0
    },
    "VISUAL_ALIGN_RIGHT": {
      "top": {"decode_hz": 2, "inference_hz": 1},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 12, "inference_hz": 10},
      "policy_hz": 0
    },
    "TRANSFER_RIGHT": {
      "top": {"decode_hz": 3, "inference_hz": 2},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 2, "inference_hz": 1},
      "policy_hz": 0
    },
    "VERIFY_RIGHT": {
      "top": {"decode_hz": 6, "inference_hz": 4},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 6, "inference_hz": 4},
      "policy_hz": 0
    },
    "DUAL_PRIVATE": {
      "top": {"decode_hz": 6, "inference_hz": 4},
      "left_wrist": {"decode_hz": 5, "inference_hz": 4},
      "right_wrist": {"decode_hz": 5, "inference_hz": 4},
      "policy_hz": 0
    },
    "POLICY_ASSIST": {
      "top": {"decode_hz": 6, "inference_hz": 4},
      "left_wrist": {"decode_hz": 0, "inference_hz": 0},
      "right_wrist": {"decode_hz": 8, "inference_hz": 6},
      "policy_hz": 10
    }
  }
}

