def Xform "so101_new_calib" (
    prepend references = @./payloads/base.usda@
    variants = {
        string Physics = "physx"
    }
    append variantSets = "Physics"
)
{
    over "Geometry"
    {
        over "base_link"
        {
            over "shoulder_link"
            {
                over "upper_arm_link"
                {
                    string isaac:nameOverride (
                        displayName = "Name Override"
                    )

                    over "lower_arm_link"
                    {
                        over "wrist_link"
                        {
                            over "gripper_link"
                            {
                                over "gripper_frame_link"
                                {
                                }

                                over "moving_jaw_so101_v1_link"
                                {
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    over "Physics"
    {
        over "shoulder_pan" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 100
            float drive:angular:physics:maxForce = 10
            float drive:angular:physics:stiffness = 1000
            float drive:angular:physics:targetPosition = 0
            float drive:angular:physics:targetVelocity = 0
            uniform token drive:angular:physics:type = "force"
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }

        over "shoulder_lift" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 100
            float drive:angular:physics:maxForce = 10
            float drive:angular:physics:stiffness = 1000
            float drive:angular:physics:targetPosition = 0
            float drive:angular:physics:targetVelocity = 0
            uniform token drive:angular:physics:type = "force"
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }

        over "elbow_flex" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 100
            float drive:angular:physics:maxForce = 10
            float drive:angular:physics:stiffness = 1000
            float drive:angular:physics:targetPosition = 0
            float drive:angular:physics:targetVelocity = 0
            uniform token drive:angular:physics:type = "force"
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }

        over "wrist_flex" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 100
            float drive:angular:physics:maxForce = 10
            float drive:angular:physics:stiffness = 1000
